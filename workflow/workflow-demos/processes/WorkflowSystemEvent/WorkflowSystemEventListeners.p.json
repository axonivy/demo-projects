  },
  "elements" : [ {
      "id" : "f1",
      "type" : "TaskEnd",
      "visual" : {
        "at" : { "x" : 640, "y" : 256 },
        "labelOffset" : { "x" : 13, "y" : 33 }
      }
    }, {
      "id" : "f3",
      "type" : "ProgramStart",
      "name" : "Task created",
      "config" : {
        "javaClass" : "ch.ivyteam.ivy.system.event.WorkflowSystemEventListenerBean",
        "userConfig" : {
          "workflowSystemEventKey" : "ivy.systemevent.workflow.task.created"
        },
        "link" : "eventLink.ivp"
      },
      "visual" : {
        "at" : { "x" : 96, "y" : 256 },
        "labelOffset" : { "x" : 13, "y" : 33 }
      },
      "connect" : [
        { "id" : "f0", "to" : "f2" }
      ]
    }, {
      "id" : "f2",
      "type" : "Script",
      "name" : "Has activator",
      "config" : {
        "output" : {
          "code" : [
            "import ch.ivyteam.ivy.workflow.ITask;",
            "import ch.ivyteam.ivy.workflow.task.IActivator;",
            "",
            "for (Long id : in.eventParameters.getIds()) {",
            "  ITask task = ivy.wf.findTask(id);",
            "  IActivator activator = task.activator();",
            "  if (activator.get() != null && !activator.isSystemUser()) {",
            "    in.taskIds.add(id);",
            "    task.customFields().stringField(\"lastActivatorHandled\").set(activator.get().getSecurityMemberId());",
            "  }",
            "}"
          ]
        }
      },
      "visual" : {
        "at" : { "x" : 232, "y" : 256 },
        "description" : "Filters tasks that triggered the event by whether they have an activator"
      },
      "connect" : [
        { "id" : "f4", "to" : "f11", "color" : "default" }
      ]
    }, {
      "id" : "f5",
      "type" : "ProgramStart",
      "name" : "Task changed",
      "config" : {
        "javaClass" : "ch.ivyteam.ivy.system.event.WorkflowSystemEventListenerBean",
        "userConfig" : {
          "workflowSystemEventKey" : "ivy.systemevent.workflow.task.changed"
        },
        "link" : "eventLink2.ivp"
      },
      "visual" : {
        "at" : { "x" : 96, "y" : 416 },
        "labelOffset" : { "x" : 13, "y" : 33 }
      },
      "connect" : [
        { "id" : "f7", "to" : "f6" }
      ]
    }, {
      "id" : "f6",
      "type" : "Script",
      "name" : "Activator has changed",
      "config" : {
        "output" : {
          "code" : [
            "import ch.ivyteam.ivy.workflow.custom.field.ICustomStringField;",
            "import ch.ivyteam.ivy.workflow.WorkflowEventKind;",
            "import ch.ivyteam.ivy.workflow.IWorkflowEvent;",
            "import ch.ivyteam.ivy.workflow.ITask;",
            "import ch.ivyteam.ivy.workflow.task.IActivator;",
            "",
            "for (Long id : in.eventParameters.getIds()) {",
            "  ITask task = ivy.wf.findTask(id);",
            "  IActivator activator = task.activator();",
            "  if (activator.get() == null || activator.isSystemUser()) {",
            "    continue;",
            "  }",
            "  ",
            "  String activatorId = activator.get().getSecurityMemberId();",
            "  ICustomStringField lastActivatorHandledField = task.customFields().stringField(\"lastActivatorHandled\");",
            "  String lastActivatorHandled = lastActivatorHandledField.get().get().toString();",
            "  if (lastActivatorHandled != activatorId) {",
            "    in.taskIds.add(id);",
            "    lastActivatorHandledField.set(activatorId);",
            "  }",
            "}"
          ]
        }
      },
      "visual" : {
        "at" : { "x" : 232, "y" : 416 },
        "description" : "Filters tasks that triggered the event by whether their activator has changed"
      },
      "connect" : [
        { "id" : "f9", "to" : "f17" }
      ]
    }, {
      "id" : "f8",
      "type" : "TaskEnd",
      "visual" : {
        "at" : { "x" : 640, "y" : 416 },
        "labelOffset" : { "x" : 13, "y" : 33 }
      }
    }, {
      "id" : "f10",
      "type" : "ProcessAnnotation",
      "name" : [
        "This demo shows how workflow system events can trigger processes. For that, a `ProcessStartEventBean` has been implemented that can be used with a program start element (see `WorkflowSystemEventListenerBean`). The bean triggers the process whenever the configured event is detected.",
        "",
        "In this example, the processes execute logic when",
        "- a new task has been assigned (has activator)",
        "- a task has been delegated (activator has changed)",
        "",
        "Of course, any custom logic can be implemented to react to workflow system events. "
      ],
      "visual" : {
        "at" : { "x" : 281, "y" : 113 },
        "size" : { "width" : 398, "height" : 158 }
      }
    }, {
