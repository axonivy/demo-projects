      "visual" : {
        "at" : { "x" : 640, "y" : 304 },
        "labelOffset" : { "x" : 13, "y" : 33 }
      }
    }, {
      "id" : "f3",
      "type" : "ProgramStart",
      "name" : "Task created",
      "config" : {
        "javaClass" : "ch.ivyteam.ivy.wfdemo.workflowsystemevent.WorkflowSystemEventListenerBean",
        "userConfig" : {
          "workflowSystemEventKey" : "ivy.systemevent.workflow.task.created"
        },
        "link" : "eventLink.ivp"
      },
      "visual" : {
        "at" : { "x" : 96, "y" : 304 },
        "labelOffset" : { "x" : 13, "y" : 33 }
      },
      "connect" : [
        { "id" : "f0", "to" : "f2" }
      ]
    }, {
      "id" : "f2",
      "type" : "Script",
      "name" : "Has responsibles",
      "config" : {
        "output" : {
          "code" : [
            "import ch.ivyteam.ivy.workflow.task.responsible.Responsibles;",
            "import ch.ivyteam.ivy.workflow.ITask;",
            "",
            "for (Long id : in.eventParameters.getIds()) {",
            "  ITask task = ivy.wf.findTask(id);",
            "  Responsibles responsibles = task.responsibles();",
            "  if (!responsibles.isSystem()) {",
            "    in.taskIds.add(id);",
            "    task.customFields().stringField(\"lastResponsiblesHandled\").set(responsibles.displayName());",
            "  }",
            "}"
          ]
        }
      },
      "visual" : {
        "at" : { "x" : 232, "y" : 304 },
        "description" : "Filters tasks that triggered the event by whether they have responsibles"
      },
      "connect" : [
        { "id" : "f4", "to" : "f11", "color" : "default" }
      ]
    }, {
      "id" : "f5",
      "type" : "ProgramStart",
      "name" : "Task changed",
      "config" : {
        "javaClass" : "ch.ivyteam.ivy.wfdemo.workflowsystemevent.WorkflowSystemEventListenerBean",
        "userConfig" : {
          "workflowSystemEventKey" : "ivy.systemevent.workflow.task.changed"
        },
        "link" : "eventLink2.ivp"
      },
      "visual" : {
        "at" : { "x" : 96, "y" : 464 },
        "labelOffset" : { "x" : 13, "y" : 33 }
      },
      "connect" : [
        { "id" : "f7", "to" : "f6" }
      ]
    }, {
      "id" : "f6",
      "type" : "Script",
      "name" : "Responsibles have changed",
      "config" : {
        "output" : {
          "code" : [
            "import ch.ivyteam.ivy.workflow.task.responsible.Responsibles;",
            "import ch.ivyteam.ivy.workflow.custom.field.ICustomStringField;",
            "import ch.ivyteam.ivy.workflow.ITask;",
            "",
            "for (Long id : in.eventParameters.getIds()) {",
            "  ITask task = ivy.wf.findTask(id);",
            "  Responsibles responsibles = task.responsibles();",
            "  if (responsibles.isSystem()) {",
            "    continue;",
            "  }",
            "  ",
            "  String responsiblesDisplayName = responsibles.displayName();",
            "  ICustomStringField lastResponsiblesHandledField = task.customFields().stringField(\"lastResponsiblesHandled\");",
            "  String lastResponsiblesHandled = lastResponsiblesHandledField.getOrNull();",
            "  if (lastResponsiblesHandled != null && lastResponsiblesHandled.equals(responsiblesDisplayName)) {",
            "    continue;",
            "  }",
            "",
            "  Boolean updatedLastResponsiblesHandled = lastResponsiblesHandledField.compareAndSet(lastResponsiblesHandled, responsiblesDisplayName);",
            "  if (updatedLastResponsiblesHandled) {",
            "    in.taskIds.add(id);",
            "  }",
            "}"
          ]
        }
      },
      "visual" : {
        "at" : { "x" : 232, "y" : 464 },
        "description" : "Filters tasks that triggered the event by whether their responsibles have changed"
      },
      "connect" : [
        { "id" : "f9", "to" : "f17" }
      ]
    }, {
      "id" : "f8",
      "type" : "TaskEnd",
      "visual" : {
        "at" : { "x" : 640, "y" : 464 },
        "labelOffset" : { "x" : 13, "y" : 33 }
      }
    }, {
      "id" : "f10",
      "type" : "ProcessAnnotation",
      "name" : [
        "This demo shows how workflow system events can trigger processes. For that, a `ProcessStartEventBean` has been implemented that can be used with a program start element (see `WorkflowSystemEventListenerBean`). The bean triggers the process whenever the configured event is detected.",
        "",
        "In this example, the processes execute logic when",
        "- a new task has been assigned (has responsibles)",
        "- a task has been delegated (responsibles have changed)",
        "",
        "Of course, any custom logic can be implemented to react to workflow system events. "
      ],
      "visual" : {
        "at" : { "x" : 281, "y" : 137 },
        "size" : { "width" : 398, "height" : 206 }
      }
    }, {
      "id" : "f11",
