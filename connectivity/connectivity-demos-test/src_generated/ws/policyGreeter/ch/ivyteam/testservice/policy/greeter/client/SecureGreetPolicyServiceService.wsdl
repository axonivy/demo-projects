  <wsdl:binding name="SecureGreetPolicyServiceServiceSoapBinding" type="targetNamespace:SecureGreetPolicyService">
    <soap:binding style="document" transport="http://schemas.xmlsoap.org/soap/http"></soap:binding>
    <wsp:PolicyReference URI="#axonSecurePolicyUsernameToken"></wsp:PolicyReference>
    <wsdl:operation name="greet">
      <soap:operation soapAction="" style="document"></soap:operation>
      <wsdl:input name="greet">
        <soap:body use="literal"></soap:body>
