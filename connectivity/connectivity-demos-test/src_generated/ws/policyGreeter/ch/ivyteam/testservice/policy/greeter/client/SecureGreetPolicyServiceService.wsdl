  <xs:complexType name="greet">
    
    <xs:sequence>
      
      <xs:element minOccurs="0" name="greet" type="xs:string"></xs:element>
    
    </xs:sequence>
  
  </xs:complexType>

  
  <xs:complexType name="greetResponse">
    
    <xs:sequence>
      
      <xs:element minOccurs="0" name="return" type="xs:string"></xs:element>
    
    </xs:sequence>
  
  </xs:complexType>


</xs:schema>
  </wsdl:types>
  <wsdl:message name="greet">
    <wsdl:part element="targetNamespace:greet" name="parameters">
    </wsdl:part>
  </wsdl:message>
  <wsdl:message name="greetResponse">
    <wsdl:part element="targetNamespace:greetResponse" name="parameters">
    </wsdl:part>
  </wsdl:message>
  <wsdl:portType name="SecureGreetPolicyService">
